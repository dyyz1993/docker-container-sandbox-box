{
  "name": "@sandbox-box/containers",
  "version": "0.1.0",
  "description": "Cloudflare Containers compatible SDK for Sandbox Box",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --reporter=verbose"
  },
  "peerDependencies": {
    "@cloudflare/containers": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@cloudflare/containers": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cloudflare/containers": "latest",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.7"
  },
  "keywords": [
    "sandbox",
    "containers",
    "cloudflare"
  ],
  "license": "MIT"
}
